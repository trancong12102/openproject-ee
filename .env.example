# Copy to .env and fill in, then: docker compose up -d --build

# REQUIRED. Generate once and never change it (changing it invalidates all
# sessions and encrypted data). Generate with:  openssl rand -hex 64
SECRET_KEY_BASE=

# Password for the bundled PostgreSQL service.
POSTGRES_PASSWORD=openproject

# The host:port you reach OpenProject on. Must match the published web port.
OPENPROJECT_HOST__NAME=localhost:8080
